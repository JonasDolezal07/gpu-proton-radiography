# ── Build artifacts ───────────────────────────────────────────────────────────
rust/target/
rust/build.log
rust/output/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
prad/bin/proton_tracer

# ── Editor / tool metadata ────────────────────────────────────────────────────
.aider*
*.bak

# ── Simulation outputs ────────────────────────────────────────────────────────
# Generated by `proton_tracer run`, `proton_tracer sweep`, validate.py, etc.
output/
runs/
sweeps/

# ── Benchmark outputs (data heavy, regenerate with run_perf.py / run_physics.py)
benchmarks/results/
benchmarks/fields/
benchmarks/plasmapy/

# ── Large data files — not in git ─────────────────────────────────────────────
# Gorgon: 422 MB HDF5 — store separately (e.g. cloud storage / Git LFS)
data/gorgon/

# MAGPIE experimental field data: ~48 MB per file — store separately
data/magpie/*.bfld
